{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string", "pattern": "^(|sha256:[a-f0-9]{64})$" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "importer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "imagePullSecrets", "hubEndpoint"],
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag", "digest", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": { "type": "string", "pattern": "^(|sha256:[a-f0-9]{64})$" },
            "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": { "name": { "type": "string", "minLength": 1 } }
              }
            ]
          }
        },
        "hubEndpoint": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": { "name": { "type": "string", "minLength": 1 } }
          }
        ]
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "automount", "annotations", "name"],
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create"],
      "properties": { "create": { "type": "boolean" } }
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "secure", "port"],
      "properties": {
        "enabled": { "type": "boolean" },
        "secure": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port"],
      "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } }
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "port", "failurePolicy", "timeoutSeconds", "tls"],
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "enum": [9443] },
        "failurePolicy": { "enum": ["Fail"] },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 30 },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["secretName", "caValidityDays", "certificateValidityDays", "certName", "keyName"],
          "properties": {
            "secretName": {
              "type": "string",
              "maxLength": 63,
              "pattern": "^(|[a-z0-9]([-a-z0-9]*[a-z0-9])?)$"
            },
            "caValidityDays": { "type": "integer", "minimum": 366 },
            "certificateValidityDays": { "type": "integer", "minimum": 1 },
            "certName": { "enum": ["tls.crt"] },
            "keyName": { "enum": ["tls.key"] }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "annotations"],
      "properties": {
        "type": { "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "annotations": { "type": "object" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "extraArgs": { "type": "array", "items": { "type": "string" } },
    "extraEnv": { "type": "array", "items": { "type": "object" } },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
    "priorityClassName": { "type": "string" }
  }
}
