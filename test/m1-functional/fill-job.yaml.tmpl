apiVersion: batch/v1
kind: Job
metadata:
  name: m1-functional-fill
  namespace: M1_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-m1-functional
spec:
  backoffLimit: 0
  activeDeadlineSeconds: 120
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kama-m1-functional
    spec:
      restartPolicy: Never
      automountServiceAccountToken: false
      enableServiceLinks: false
      nodeSelector:
        kubernetes.io/hostname: M1_WORKER_NODE
      tolerations:
        - operator: Exists
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        fsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: fill
          image: M1_HELPER_IMAGE
          imagePullPolicy: Never
          command:
            - /m1-functional-helper
          args:
            - fill
            - --root=/cache
            - --release-bytes=524288
            - --max-free-bytes=921600
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
          resources:
            requests:
              cpu: 5m
              memory: 8Mi
            limits:
              cpu: 100m
              memory: 32Mi
          volumeMounts:
            - name: cache
              mountPath: /cache
      volumes:
        - name: cache
          persistentVolumeClaim:
            claimName: m1-functional-full
