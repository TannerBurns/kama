apiVersion: v1
kind: Pod
metadata:
  name: e2e-rwo-wrong-node
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  restartPolicy: Never
  automountServiceAccountToken: false
  enableServiceLinks: false
  nodeSelector:
    kubernetes.io/hostname: E2E_WRONG_NODE
  tolerations:
    - operator: Exists
  securityContext:
    runAsNonRoot: true
    runAsUser: 65532
    runAsGroup: 65532
    seccompProfile:
      type: RuntimeDefault
  containers:
    - name: reader
      image: E2E_HELPER_IMAGE
      imagePullPolicy: Never
      command:
        - /e2e-storage-helper
      args:
        - verify-tree
        - --root=/artifact
        - --expected-file=model.gguf
        - --expected-sha256=0e1ec3e53960fdc1556515b1368222af8acbd0d346447b1a724bdaaeb3fa1e94
      securityContext:
        allowPrivilegeEscalation: false
        capabilities:
          drop:
            - ALL
        readOnlyRootFilesystem: true
      resources:
        requests:
          cpu: 5m
          memory: 8Mi
        limits:
          cpu: 100m
          memory: 32Mi
      volumeMounts:
        - name: artifact
          mountPath: /artifact
          subPath: E2E_RWO_SUBPATH
          readOnly: true
  volumes:
    - name: artifact
      persistentVolumeClaim:
        claimName: e2e-storage-source
        readOnly: true
