apiVersion: batch/v1
kind: Job
metadata:
  name: e2e-storage-fill
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  backoffLimit: 0
  activeDeadlineSeconds: 120
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kama-e2e-storage
    spec:
      restartPolicy: Never
      automountServiceAccountToken: false
      enableServiceLinks: false
      nodeSelector:
        kubernetes.io/hostname: E2E_WORKER_NODE
      tolerations:
        - operator: Exists
      securityContext:
        runAsNonRoot: true
        runAsUser: 65532
        runAsGroup: 65532
        fsGroup: 65532
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: fill
          image: E2E_HELPER_IMAGE
          imagePullPolicy: Never
          command:
            - /e2e-storage-helper
          args:
            - fill
            - --root=/cache
            - --release-bytes=524288
            - --max-free-bytes=921600
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
          resources:
            requests:
              cpu: 5m
              memory: 8Mi
            limits:
              cpu: 100m
              memory: 32Mi
          volumeMounts:
            - name: cache
              mountPath: /cache
      volumes:
        - name: cache
          persistentVolumeClaim:
            claimName: e2e-storage-full
