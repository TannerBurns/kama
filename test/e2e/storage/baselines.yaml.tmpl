apiVersion: kama.tannerburns.github.io/v1alpha1
kind: ModelArtifact
metadata:
  name: e2e-rwx-baseline
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  format: GGUF
  entrypoint: model.gguf
  cacheRef:
    name: e2e-storage-rwx
  verification:
    expectedSHA256: "0e1ec3e53960fdc1556515b1368222af8acbd0d346447b1a724bdaaeb3fa1e94"
    expectedSize: 180
  source:
    persistentVolumeClaim:
      claimName: e2e-storage-source
      rootPath: models
      importPolicy: Copy
