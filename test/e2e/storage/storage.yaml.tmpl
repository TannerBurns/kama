apiVersion: v1
kind: Namespace
metadata:
  name: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: e2e-storage-source-local
  labels:
    app.kubernetes.io/name: kama-e2e-storage
provisioner: kubernetes.io/no-provisioner
reclaimPolicy: Retain
volumeBindingMode: Immediate
---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: e2e-storage-full-local
  labels:
    app.kubernetes.io/name: kama-e2e-storage
provisioner: kubernetes.io/no-provisioner
reclaimPolicy: Retain
volumeBindingMode: Immediate
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: e2e-storage-source
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  capacity:
    storage: 16Mi
  volumeMode: Filesystem
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: e2e-storage-source-local
  local:
    path: /var/local/kama-e2e-storage-source
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - E2E_WORKER_NODE
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: e2e-storage-full
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  capacity:
    storage: 8Mi
  volumeMode: Filesystem
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: e2e-storage-full-local
  local:
    path: /var/local/kama-e2e-storage-full
  nodeAffinity:
    required:
      nodeSelectorTerms:
        - matchExpressions:
            - key: kubernetes.io/hostname
              operator: In
              values:
                - E2E_WORKER_NODE
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: e2e-storage-source
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  accessModes:
    - ReadWriteOnce
  volumeMode: Filesystem
  storageClassName: e2e-storage-source-local
  resources:
    requests:
      storage: 16Mi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: e2e-storage-full
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  accessModes:
    - ReadWriteOnce
  volumeMode: Filesystem
  storageClassName: e2e-storage-full-local
  resources:
    requests:
      storage: 8Mi
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: e2e-storage-rwx
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  accessModes:
    - ReadWriteMany
  volumeMode: Filesystem
  storageClassName: E2E_RWX_STORAGE_CLASS
  resources:
    requests:
      storage: 32Mi
---
apiVersion: kama.tannerburns.github.io/v1alpha1
kind: ModelCache
metadata:
  name: e2e-storage-rwx
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  retentionPolicy: Retain
  storage:
    existingClaim:
      name: e2e-storage-rwx
---
apiVersion: kama.tannerburns.github.io/v1alpha1
kind: ModelCache
metadata:
  name: e2e-storage-full
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
spec:
  retentionPolicy: Retain
  storage:
    existingClaim:
      name: e2e-storage-full
