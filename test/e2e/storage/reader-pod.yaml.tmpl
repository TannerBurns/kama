apiVersion: v1
kind: Pod
metadata:
  name: E2E_READER_NAME
  namespace: E2E_NAMESPACE
  labels:
    app.kubernetes.io/name: kama-e2e-storage
    kama.tannerburns.github.io/e2e-reader: "true"
spec:
  restartPolicy: Never
  automountServiceAccountToken: false
  enableServiceLinks: false
  nodeSelector:
    kubernetes.io/hostname: E2E_READER_NODE
  tolerations:
    - operator: Exists
  securityContext:
    runAsNonRoot: true
    runAsUser: 65532
    runAsGroup: 65532
    fsGroup: 65532
    seccompProfile:
      type: RuntimeDefault
  containers:
    - name: reader
      image: E2E_HELPER_IMAGE
      imagePullPolicy: Never
      command:
        - /e2e-storage-helper
      args:
        - verify-tree
        - --root=/artifact
        - --expected-file=model.gguf
        - --expected-sha256=0e1ec3e53960fdc1556515b1368222af8acbd0d346447b1a724bdaaeb3fa1e94
        - --ready-file=/tmp/ready
        - --hold=300s
      readinessProbe:
        exec:
          command:
            - /e2e-storage-helper
            - ready
            - --file=/tmp/ready
        periodSeconds: 1
        timeoutSeconds: 2
        failureThreshold: 120
      securityContext:
        allowPrivilegeEscalation: false
        capabilities:
          drop:
            - ALL
        readOnlyRootFilesystem: true
      resources:
        requests:
          cpu: 5m
          memory: 8Mi
        limits:
          cpu: 100m
          memory: 32Mi
      volumeMounts:
        - name: artifact
          mountPath: /artifact
          subPath: E2E_ARTIFACT_SUBPATH
          readOnly: true
        - name: tmp
          mountPath: /tmp
  volumes:
    - name: artifact
      persistentVolumeClaim:
        claimName: E2E_ARTIFACT_CLAIM
        readOnly: true
    - name: tmp
      emptyDir: {}
